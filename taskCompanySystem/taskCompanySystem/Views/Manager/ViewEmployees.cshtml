@using taskCompanySystem.Identity
@model IEnumerable<ApplicationUser>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Company Employees</h2>
        <a asp-action="CreateEmployee" class="btn btn-success">Add New Employee</a>
    </div>

    <!-- Filter Form -->
    <form asp-action="ViewEmployees" method="get" class="my-3 d-flex gap-2">
        <input type="text" name="searchName" class="form-control" placeholder="Search by name..." />
        <button type="submit" class="btn btn-primary">Filter</button>
    </form>

    <div class="table-responsive">
        <table class="table table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Photo</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>National ID</th>
                    <th>Phone</th>
                    <th>Birthdate</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td>
                            <img src="@emp.PhotoPath" class="rounded-circle" width="50" height="50" alt="Profile" />
                        </td>
                        <td><strong>@emp.FullName</strong><br /><small>@emp.Email</small></td>
                        <td>@emp.Department?.Name</td>
                        <td>@emp.NationalID</td>
                        <td>@emp.PhoneNumber</td>
                        <td>@emp.BirthDate.ToShortDateString()</td>
                        <td>@emp.MaritalStatus</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>