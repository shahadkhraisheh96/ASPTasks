@model Students

<h2>Edit Student</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <label>Name</label>
    <input asp-for="Name" />
    <br />

    <label>Age</label>
    <input asp-for="Age" />
    <br />

    <label>Email</label>
    <input asp-for="Email" />
    <br />

    <button type="submit">Update</button>
</form>